{
  "name": "@bible-commentary/api",
  "version": "1.0.0",
  "description": "Bible Commentary REST API - Serverless commentary generation and serving",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node build.js",
    "type-check": "tsc --noEmit",
    "dev": "func start",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write 'src/**/*.ts'",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@azure/functions": "^4.5.0",
    "@azure/identity": "^4.1.0",
    "@bible-commentary/skill": "file:../lib",
    "redis": "^4.6.13"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "bible",
    "commentary",
    "rest-api",
    "azure-functions",
    "serverless",
    "theology"
  ]
}
